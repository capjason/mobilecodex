# MobileCodex host server
HOST=0.0.0.0
PORT=8787

# Optional frontend default working directory shown in the launcher.
# Leave unset to default to "~".
VITE_DEFAULT_WORKDIR=~/workspace

# Optional Vite dev-server proxy target.
VITE_DEV_BACKEND_URL=http://127.0.0.1:8787

# Optional iOS remote build host, used by scripts/build-ios-on-mac.sh.
# Example: user@mac-host.example.com
MAC_HOST=
REMOTE_DIR=~/Desktop/mobilecodex-build
SCHEME=MobileCodex

# Optional HTTPS setup, used by scripts/install-https-caddy.sh.
MOBILECODEX_DOMAIN=mobilecodex.example.com
ACME_EMAIL=
